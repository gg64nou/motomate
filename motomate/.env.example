# Required
DATABASE_URL=./data/motomate.db
AUTH_SECRET=change-me-in-production-min-32-chars   # openssl rand -hex 32

# Auth
AUTH_COOKIE_SECURE=false
AUTH_ALLOW_REGISTRATION=true
# ALTCHA_HMAC_KEY=change-me-min-32-chars

# Storage
STORAGE_ADAPTER=local
STORAGE_LOCAL_PATH=./uploads

# S3-compatible (used when STORAGE_ADAPTER=s3)
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_REGION=eu-west-1
S3_BUCKET=motomate
S3_ACCESS_KEY=
S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=true

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@motomate.local
# SMTP_SECURE=true
# SMTP_REJECT_UNAUTHORIZED=false

# App
TZ=Europe/Amsterdam
BODY_SIZE_LIMIT=20971520
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_APP_ORIGINS=http://localhost:5173
PUBLIC_APP_NAME=MotoMate

# Demo
PUBLIC_DEMO_ENABLED=false

# Scheduler
CRON_INTERVAL_HOURS=1

# Push notifications (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@motomate.local
